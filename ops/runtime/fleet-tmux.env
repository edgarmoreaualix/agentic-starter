# Copy to ops/runtime/fleet-tmux.env and map each orchestrator to a tmux pane.
# Example discovery command:
# tmux -L fleet list-panes -a -F '#{pane_id} #{session_name}:#{window_index}.#{pane_index} #{pane_title}'

# Dedicated tmux socket for fleet orchestration (avoids sandbox issues with default socket path).
TMUX_SOCKET_NAME="fleet"
TMUX_TMPDIR="/tmp"
TMUX_SOCKET_PATH="/tmp/fleet.sock"

TMUX_ORCH_01_PANE="%0"
TMUX_ORCH_02_PANE="%1"
TMUX_ORCH_03_PANE="%2"
TMUX_ORCH_04_PANE="%3"
TMUX_ORCH_05_PANE="%4"
TMUX_ORCH_06_PANE="%5"

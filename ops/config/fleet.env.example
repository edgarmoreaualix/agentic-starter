# Copy to ops/config/fleet.env and customize.

# Comma-separated orchestrator IDs. Example for 6 control terminals:
# orch-01,orch-02,orch-03,orch-04,orch-05,orch-06
FLEET_ORCHESTRATORS="orch-01,orch-02,orch-03,orch-04,orch-05,orch-06"

# Default worker roles for orchestrators without explicit overrides.
WORKER_ROLES="worker-backend,worker-frontend,worker-qa,worker-sentinel"

# Optional per-orchestrator worker overrides.
# Format: orch-id:worker-a,worker-b;orch-id:worker-a,worker-c
# Example:
# ORCH_WORKER_MATRIX="orch-01:worker-backend,worker-frontend,worker-marketing;orch-02:worker-backend,worker-frontend,worker-lawyer"
ORCH_WORKER_MATRIX=""

# Required JSON fields in each worker summary file.
SUMMARY_REQUIRED_FIELDS="task_id,status,files_changed,tests_run,commit_sha,summary,risks"

# Soft target used in v2 aggregate dashboard.
TARGET_COMMITS_PER_WORKER="3"
